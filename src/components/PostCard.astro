---
const { title, excerpt, date, slug, tags, page } = Astro.props;
import Tag from "@components/Tag.astro";

import "@styles/postcard.css";
import FormattedDate from "@components/FormattedDate.astro";
---

<article class="card">
    <div class="content">
        <div class="date">
            <FormattedDate date={date} />
        </div>

        <h5 class="title">{title}</h5>
        <p class="excerpt">{excerpt}</p>

        {
            tags && tags.length > 0 && (
                <div class="tags">
                    {tags.map((tag: string) => (
                        <Tag name={tag} />
                    ))}
                </div>
            )
        }

        <div class="card-footer">
            <a class="read-more" href={`/blog/${slug}?page=${page}`}
                >Read More →</a
            >
        </div>
    </div>
</article>
